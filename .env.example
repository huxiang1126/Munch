# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── 注意 ──
# 需要在 Supabase Dashboard 手动创建 Storage Bucket:
# Bucket 名称: template-images
# 公开访问: true（模板缩略图需要公开访问）
# 允许的 MIME: image/png, image/jpeg, image/webp

# ── AIGC 统一 API 网关 ──
AIGC_API_BASE_URL=https://aigcapi.top/v1

# ── Kie 图像任务 API ──
KIE_API_BASE_URL=https://api.kie.ai
KIE_UPLOAD_BASE_URL=https://kieai.redpandaai.co
KIE_API_KEY=
KIE_LLM_BASE_URL=https://api.kie.ai/gpt-5-2/v1
KIE_LLM_API_KEY=
ENABLE_TEMPLATE_LLM_COMPILATION=false

# ── 图像模型 API Key（每个模型独立 Key）──
NANO_BANANA_2_API_KEY=
NANO_BANANA_PRO_4K_API_KEY=
NANO_BANANA_PRO_2K_API_KEY=

# ── Inngest ──
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── 应用配置 ──
NEXT_PUBLIC_APP_URL=https://munch.love
CREDITS_EXCHANGE_RATE=100
